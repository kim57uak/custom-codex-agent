# CORS
CUSTOM_CODEX_AGENT_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Write API token (X-API-Token)
CUSTOM_CODEX_AGENT_WRITE_API_TOKEN=

# Founder name shown in org chart
CUSTOM_CODEX_AGENT_FOUNDER_NAME=대표이사

# Codex home
CUSTOM_CODEX_AGENT_CODEX_HOME=~/.codex

# Run store / execution
CUSTOM_CODEX_AGENT_RUN_DB_NAME=custom_codex_agent_runs.sqlite
CUSTOM_CODEX_AGENT_RUN_MAX_CONCURRENCY=2
CUSTOM_CODEX_AGENT_RUN_TIMEOUT_SECONDS=1800
CUSTOM_CODEX_AGENT_RUN_PROMPT_MAX_LENGTH=12000
CUSTOM_CODEX_AGENT_WORKSPACE_ROOT=~/workspace/custom-codex-agent

# Codex CLI execution
CUSTOM_CODEX_AGENT_CODEX_CLI_EXECUTABLE=codex
# Comma-separated args
CUSTOM_CODEX_AGENT_CODEX_CLI_SUBCOMMAND=exec,--sandbox,danger-full-access
