@startuml
title Custom Codex Agent - Use Case Diagram

left to right direction
actor User

rectangle "Custom Codex Agent System" {
    usecase "Execute Single Run" as UC1
    usecase "Execute Multi-step Workflow" as UC2
    usecase "Switch AI Engine (Gemini/Codex)" as UC3
    usecase "Retry Failed Run" as UC4
    usecase "Retry with Engine Override" as UC5
    usecase "View Real-time Logs" as UC6
    usecase "Cancel Active Task" as UC7
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7

UC5 ..> UC3 : <<include>>
UC4 ..> UC1 : <<extend>>
@enduml
